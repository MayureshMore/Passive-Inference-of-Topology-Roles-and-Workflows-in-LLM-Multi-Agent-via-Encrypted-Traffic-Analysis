# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Environment files (may contain secrets) ──────────────────────────────────
.env
.env.*
*.env

# ── Data directories (large files, never commit raw pcaps, npz, or models) ───
# Ignore EVERYTHING under data/ (raw_*, processed_*, models, traces, defended,
# background, *_sdk variants, ...) so captures never reach the public repo.
# The ONLY exception is data/results/ — small JSON result files kept as
# reviewable outputs.  (Previously only data/raw|processed|models|traces were
# listed, so the *_sdk / raw_b / background dirs leaked 16k+ files into git.)
data/*
!data/results/

# ── Pre-migration code backup (snapshot, not source) ─────────────────────────
.pre_sdk_backup/

# ── graphify outputs (regenerable via /graphify; keep repo clean) ────────────
graphify-out/

# ── Packet capture files ──────────────────────────────────────────────────────
*.pcap
*.pcapng
*.cap

# ── Trained model checkpoints ────────────────────────────────────────────────
*.pkl
*.pt
*.pth
*.onnx
*.joblib

# ── Jupyter notebooks (use scripts/ instead) ─────────────────────────────────
*.ipynb
.ipynb_checkpoints/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverrideAttribute

# ── IntelliJ / PyCharm ────────────────────────────────────────────────────────
.idea/
*.iml
*.iws

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Coverage ──────────────────────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Mininet / network emulation ───────────────────────────────────────────────
*.mnlog
